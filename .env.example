# aut8ma Multi-Agent System — Variables de Entorno
# Copiar este archivo a .env y completar con valores reales
# NUNCA commitear el archivo .env al repositorio

# ─────────────────────────────────────────────────────────────
# ANTHROPIC (requerido para Claude Code y los agentes)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─────────────────────────────────────────────────────────────
# N8N (opcional: para integración directa futura)
# Actualmente los agentes entregan JSON en chat, no via API
# ─────────────────────────────────────────────────────────────
N8N_BASE_URL=https://tu-n8n.tudominio.com
N8N_API_KEY=

# ─────────────────────────────────────────────────────────────
# NOTIFICACIONES INTERNAS (opcional)
# Para alertas a Tavo cuando se completa una entrega
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────
# OPENAI (requerido en las automatizaciones N8N del cliente)
# No lo usan los agentes directamente — es para los JSONs
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────
# YCLOUD (para las automatizaciones de WhatsApp del cliente)
# Referenciado en los JSONs generados
# ─────────────────────────────────────────────────────────────
YCLOUD_API_KEY=

# ─────────────────────────────────────────────────────────────
# GROQ (para Whisper y Llama — incluido en JSONs N8N)
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ─────────────────────────────────────────────────────────────
# SUPABASE (para RAG en automatizaciones N8N del cliente)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ─────────────────────────────────────────────────────────────
# ELEVENLABS (para voz en automatizaciones del cliente)
# ─────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─────────────────────────────────────────────────────────────
# BASE DE DATOS (si se migra tracking de clientes a DB)
# Actualmente el tracking es via archivos markdown en clients/
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/aut8ma

# ─────────────────────────────────────────────────────────────
# AGENCIA (identificadores internos)
# ─────────────────────────────────────────────────────────────
AGENCY_NAME=aut8ma
AGENCY_COUNTRY=Venezuela
AGENCY_FOUNDER=Tavo
